QUEUE_SERVER_URL=https://example.com/admin/queue_worker_api.php
QUEUE_SECRET_KEY=replace-with-queue-secret
POLL_INTERVAL=15
WORKER_ID=worker-local-1
SUPPORTED_TYPES=pdf_anonymise,pdf_textify,included_study_extract,url_ingest,research_resolve,org_profile_refresh,portal_ingest,cortex_sync,intel_extract
LOG_LEVEL=INFO
TEMP_DIR=./tmp
HEARTBEAT_INTERVAL=60
REQUEST_TIMEOUT=60
# Optional: override queue monitor state path
# QUEUE_MONITOR_STATE_PATH=./tmp/queue_monitor_state.json

# Proxycurl — LinkedIn profile lookups for Market Radar Stakeholder Watch scans
# Get key at https://nubela.co/proxycurl (~$0.01/lookup)
# Leave blank to skip LinkedIn lookups (web search still runs)
PROXYCURL_API_KEY=

# Cortex-owned Intel mailbox intake (optional)
INTEL_IMAP_HOST=imap.gmail.com
INTEL_IMAP_PORT=993
INTEL_IMAP_USERNAME=
INTEL_IMAP_PASSWORD=
INTEL_IMAP_FOLDER=INBOX
INTEL_IMAP_ORG_NAME=Longboardfella
INTEL_IMAP_POLL_INTERVAL=60
INTEL_IMAP_POLL_LIMIT=10
INTEL_IMAP_SEARCH=UNSEEN
INTEL_IMAP_MARK_SEEN_ON_SUCCESS=0
# Comma-separated allowlist. Leave blank to accept all senders.
INTEL_ALLOWED_SENDERS=
INTEL_SOURCE_SYSTEM=cortex_mailbox

# Optional website callback for processed intel results.
# If blank, Cortex writes JSON payloads to the external DB outbox instead.
INTEL_RESULTS_POST_URL=
# Optional separate endpoint for structured note/document mail such as org charts and strategic plans.
# If blank, Cortex falls back to INTEL_RESULTS_POST_URL or derives /lab/market_radar_api.php?action=ingest_intel_note
# from the legacy import_cortex_extract URL when possible.
INTEL_NOTE_POST_URL=
INTEL_RESULTS_POST_SECRET=
INTEL_RESULTS_POST_TIMEOUT=30

# Optional direct Market Radar profile-import endpoint for CSV mailbox imports.
# If blank, Cortex derives /lab/market_radar_api.php?action=bulk_import_profiles
# from INTEL_RESULTS_POST_URL or QUEUE_SERVER_URL.
INTEL_PROFILE_IMPORT_URL=
INTEL_PROFILE_IMPORT_TIMEOUT=45

# Optional SMTP settings for mailbox auto-replies.
# Defaults to the IMAP credentials and Gmail SMTP if left blank.
INTEL_SMTP_HOST=smtp.gmail.com
INTEL_SMTP_PORT=465
INTEL_SMTP_USERNAME=
INTEL_SMTP_PASSWORD=
INTEL_SMTP_USE_SSL=1
INTEL_REPLY_FROM=
